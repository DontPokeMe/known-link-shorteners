{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["domain", "type", "status", "added_at", "source", "evidence"],
    "properties": {
      "domain": {
        "type": "string",
        "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?)*$",
        "description": "Lowercase domain, no paths, punycode normalized"
      },
      "type": {
        "type": "string",
        "enum": ["shortener", "redirector", "tracking"]
      },
      "status": {
        "type": "string",
        "enum": ["active", "defunct", "malicious"]
      },
      "added_at": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
        "description": "ISO 8601 date (YYYY-MM-DD)"
      },
      "source": {
        "type": "string",
        "enum": ["submission", "internal"]
      },
      "evidence": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "format": "uri"
        }
      },
      "notes": {
        "type": "string",
        "description": "Optional notes"
      }
    },
    "additionalProperties": false
  }
}
