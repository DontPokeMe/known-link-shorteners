{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["domain", "origin", "last_status", "last_checked_at"],
    "properties": {
      "domain": {
        "type": "string",
        "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?)*$",
        "description": "Lowercase domain"
      },
      "origin": {
        "type": "string",
        "enum": ["shortener", "redirector", "tracking"]
      },
      "last_status": {
        "type": ["string", "integer"],
        "description": "403, 404, or dns_error for inactive list"
      },
      "last_checked_at": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
        "description": "ISO date YYYY-MM-DD"
      },
      "notes": {
        "type": ["string", "null"]
      }
    },
    "additionalProperties": false
  }
}
